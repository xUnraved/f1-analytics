{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend starten",
      "type": "shell",
      "command": "mvn quarkus:dev",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "f1analytics"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Frontend starten",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "f1analytics"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "F1 Analytics starten",
      "dependsOn": ["Backend starten", "Frontend starten"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    }
  ]
}
